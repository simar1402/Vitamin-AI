# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL for OAuth redirects (required in production)
# Production: https://vitaminai.club
# Local dev:  http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# ContentPackage: YouTube feed
YOUTUBE_API_KEY=

# Resend (email)
RESEND_API_KEY=
# Optional — defaults to VitaminAI <onboarding@resend.dev> for testing.
# Use a verified domain on production, e.g. VitaminAI <hello@yourdomain.com>
RESEND_FROM=

# Daily digest cron — Vercel invokes /api/send-daily-digest daily at 9:00 AM IST (03:30 UTC)
# and sends Authorization: Bearer <CRON_SECRET>. Set CRON_SECRET in Vercel env vars.
CRON_SECRET=
